{
  "name": "synapse",
  "version": "1.0.0",
  "description": "This repository contains the Cloudflare Workers setup for deploying the Synapse campus assistant backend and frontend. The Workers act as an API gateway, routing requests between Cloudflare and the Gleam backend.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",

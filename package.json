    "deploy:production": "wrangler deploy --env production",
    "tail": "wrangler tail",
    "secrets": "wrangler secret list"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idk4whatamiusing/synapse.git"
  },
